projection;
strict (2);
use draft;

define behavior for ZC_CIT_B_22CS157 alias Bus {
  use create;
  use update;
  use delete;

  // Explicitly expose draft actions required by strict(2)
  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Passengers { create; with draft; }
}

define behavior for ZC_CIT_I_157 alias Passenger {
  use update;
  use delete;

  use association _Bus { with draft; }
}